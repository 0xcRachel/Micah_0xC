{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Micah_0xC",
  "version": "0.1.0",
  "identifier": "com.micah0xc.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Micah 0xC",
        "width": 1380,
        "height": 760,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "devtools": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/dlls/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW1teV9wdWJsaWNfa2V5X2R1bW15X3B1YmxpY19rZXk=",
      "endpoints": [
        "https://github.com/0xcRachel/Micah_0xC/releases/latest/download/latest.json"
      ]
    }
  }
}